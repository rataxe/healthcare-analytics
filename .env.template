# .env.template — Kopiera till .env och fyll i dina värden
# LÄGG ALDRIG .env i Git!

# Azure SQL
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=HealthcareAnalyticsDB

# Azure Key Vault
KEY_VAULT_URL=https://your-kv.vault.azure.net/

# Fabric / Service Principal
FABRIC_TENANT_ID=your-tenant-id
FABRIC_CLIENT_ID=your-sp-client-id
FABRIC_CLIENT_SECRET=your-sp-secret
FABRIC_WORKSPACE_ID=your-workspace-guid
FABRIC_CAPACITY_ID=your-capacity-guid

# Lakehouse-namn (matcha Fabric UI)
BRONZE_LAKEHOUSE=bronze_lakehouse
SILVER_LAKEHOUSE=silver_lakehouse
GOLD_LAKEHOUSE=gold_lakehouse

# MLflow
MLFLOW_EXPERIMENT=healthcare-analytics-v1
